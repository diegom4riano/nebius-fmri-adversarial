# Copy to .env and fill in all values before running make commands.
# .env is gitignored — never commit it.

# Your Nebius project ID — found in the console at console.eu-north1.nebius.cloud
# under the project overview page URL: /projects/<project-id>
PARENT_ID=<your-project-id>

# Numeric bucket ID for your S3 bucket.
# Get it with:
#   nebius storage bucket get-by-name \
#     --name <your-bucket-name> \
#     --parent-id ${PARENT_ID} \
#     --format jsonpath='{.metadata.id}'
BUCKET_ID=<numeric-bucket-id>

# Name of your S3 bucket (the human-readable name you chose)
S3_BUCKET=<your-bucket-name>
S3_ENDPOINT=https://storage.eu-north1.nebius.cloud
